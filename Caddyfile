# ── LIBITEX Production ──

# Tout passe par libitex.lunion-lab.com
# Caddy gere le SSL automatiquement via Let's Encrypt

libitex.lunion-lab.com {
	# API — tout ce qui commence par /api/
	handle /api/* {
		reverse_proxy api:3000
	}

	# Swagger docs
	handle /docs* {
		reverse_proxy api:3000
	}

	# Frontend — tout le reste
	handle {
		reverse_proxy web:3001
	}
}

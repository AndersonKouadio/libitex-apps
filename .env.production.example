# ── Database (Neon) ──
DATABASE_URL=postgresql://neondb_owner:npg_O4IPmhS7lqHA@ep-cool-unit-ap2c7kn4-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ── Redis ──
REDIS_URL=redis://redis:6379

# ── JWT ──
JWT_SECRET=libitex-jwt-secret-change-en-prod-64-chars-minimum-xxxxxxxxxx
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=libitex-refresh-secret-change-en-prod-64-chars-minimum-xxxxxxx
JWT_REFRESH_EXPIRES_IN=7d

# ── App ──
NODE_ENV=production
PORT=3000
CORS_ORIGINS=https://libitex-pro.lunion-lab.com

# ── Stockage objet (MinIO) ──
#
# OBLIGATOIRE : sans STORAGE_ACCESS_KEY ni STORAGE_SECRET_KEY, les uploads
# d'images echouent au runtime avec « Variables manquantes ».
# Les memes valeurs servent aussi a MinIO (MINIO_ROOT_USER/MINIO_ROOT_PASSWORD).
#
# Generer un secret solide :   openssl rand -hex 32
#
# Si MinIO tourne deja, NE PAS changer ces valeurs sinon le bucket existant
# devient inaccessible. Verifier les valeurs actuelles avec :
#   docker compose -f docker-compose.prod.yml exec minio env | grep MINIO_ROOT
STORAGE_ENDPOINT=http://minio:9000
STORAGE_PUBLIC_ENDPOINT=https://libitex-storage.lunion-lab.com
STORAGE_REGION=us-east-1
STORAGE_BUCKET=libitex-public
STORAGE_ACCESS_KEY=libitex-prod
STORAGE_SECRET_KEY=libitex-storage-secret-change-en-prod-64-chars-minimum
